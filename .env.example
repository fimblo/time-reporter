# Optional: when the frontend is served without a proxy (e.g. `vite preview` on :4173),
# point the browser at the API explicitly:
# VITE_API_URL=http://localhost:3001

# API server port (default 3001)
# PORT=3001

# SQLite file path (default: ./data/time-reporter.sqlite relative to project root)
# TIME_REPORTER_DB=./data/time-reporter.sqlite
