# No .env.local is needed for normal development.
# The Vite dev server proxies /api/* to http://localhost:3001 automatically.

# Set VITE_API_URL only if you need to point the browser at a different API host,
# e.g. when running `vite preview` (port 4173 has no proxy) or a remote backend:
# VITE_API_URL=http://localhost:3001

# API server port (default 3001)
# PORT=3001

# SQLite file path (default: ./data/time-reporter.sqlite relative to project root)
# TIME_REPORTER_DB=./data/time-reporter.sqlite
